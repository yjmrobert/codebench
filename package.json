{
  "name": "codebench",
  "version": "0.1.0",
  "description": "Language-agnostic CLI tool that analyzes codebases and produces a unified health score",
  "type": "module",
  "bin": {
    "codebench": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
